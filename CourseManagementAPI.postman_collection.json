                {
                  "key": "courseDescription",
                  "value": "Learn React from scratch",
                  "type": "text"
                },
                {
                  "key": "whatYouWillLearn",
                  "value": "Components, Hooks, State Management",
                  "type": "text"
                },
                {
                  "key": "category",
                  "value": "category_id_here",
                  "type": "text"
                },
                {
                  "key": "thumbnail",
